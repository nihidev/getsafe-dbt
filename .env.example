# Copy this file to .env and fill in real values

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Metabase — API key from Metabase Admin > API Keys
# METABASE_URL is set automatically in docker-compose to http://host.docker.internal:12345
METABASE_API_KEY=mb_...

# Supabase connection (same values as profiles.yml)
SUPABASE_HOST=aws-1-eu-west-2.pooler.supabase.com
SUPABASE_PORT=5432
SUPABASE_DB=postgres
SUPABASE_USER=postgres.wqpmvnqggqpoajbzmtcu
SUPABASE_PASSWORD=your_supabase_password

# dbt gold schema name in Supabase (default: public_gold)
GOLD_SCHEMA=public_gold

# Linear
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=5a12d787-f028-47d5-91bf-c7b9c45a4ecc

# GitHub — needs repo scope to open PRs
GITHUB_PAT=ghp_...
GITHUB_REPO=nihidev/getsafe-dbt
